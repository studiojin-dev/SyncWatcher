{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "conflict-review"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Volumes/**"
        }
      ]
    },
    "fs:default",
    "dialog:default",
    "window-state:default",
    "updater:default",
    "process:default"
  ]
}
