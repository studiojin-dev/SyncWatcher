{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sync Watcher",
  "version": "1.4.0",
  "identifier": "dev.studiojin.syncwatcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sync Watcher",
        "visible": false,
        "width": 800,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "/Volumes/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Jeongjin Kim (B75RUJT6KD)",
      "dmg": {
        "background": "resources/dmg/install-guide.png",
        "windowSize": {
          "width": 860,
          "height": 520
        },
        "appPosition": {
          "x": 224,
          "y": 384
        },
        "applicationFolderPosition": {
          "x": 694,
          "y": 384
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0ODExMEU1MkQxREIxN0YKUldSL3NSMHQ1UkNCNUE0VXQxSlR2MkZidjNjME04VkNId3YzOHJueFpNUjh5Vzc2STNSQUxtNnkK",
      "endpoints": [
        "https://github.com/studiojin-dev/SyncWatcher/releases/latest/download/latest.json"
      ]
    }
  }
}